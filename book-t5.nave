        // 9. ignite.js (el cargador)
        page09: {
            id: 'page09',
            label: '🔥 ignite.js',
            tomo: 5,
            render: function(container) {
                container.innerHTML = `
                    <div style="padding: 1rem 0.5rem;">
                        <h2 class="chapter-title">🔥 ignite.js – El Cargador Efímero</h2>
                        <div class="explain-box">
                            <div class="emoji-deco">⚡</div>
                            <p><strong>Responsabilidad:</strong> Punto de entrada único. Carga secuencialmente los módulos del núcleo.</p>
                            <p><strong>Características:</strong></p>
                            <ul class="friendly-list">
                                <li>Es el único archivo <code>.js</code> del sistema.</li>
                                <li>No modifica <code>index.html</code> (se añade como script).</li>
                                <li>Carga los módulos en orden: <code>core.mizu</code> → <code>hauler.mizu</code> → <code>dockmaster.mizu</code> → <code>lighthouse.mizu</code> → <code>dock.mizu</code> → <code>opscenter.mizu</code>.</li>
                                <li>Reintentos (3) y timeout (10s) por módulo.</li>
                                <li>Muestra errores críticos en pantalla si el core falla.</li>
                                <li>Después de cargar, desaparece sin dejar rastro (no expone nada en <code>window</code>).</li>
                            </ul>
                        </div>
                    </div>
                `;
            }
        },

        // 10. Comparación con v1.3.0
        page10: {
            id: 'page10',
            label: '📊 Comparativa v1.3.0 vs v2.2.0',
            tomo: 5,
            render: function(container) {
                container.innerHTML = `
                    <div style="padding: 1rem 0.5rem;">
                        <h2 class="chapter-title">📊 Comparativa con v1.3.0 (Legacy)</h2>
                        <div class="explain-box">
                            <div class="emoji-deco">📈</div>
                            <p><strong>Evolución arquitectónica:</strong></p>
                            <table class="model-table">
                                <thead><tr><th>Aspecto</th><th>v1.3.0</th><th>v2.2.0</th></tr></thead>
                                <tbody>
                                    <tr><td>Archivos núcleo</td><td>10</td><td>6 (todos .mizu)</td></tr>
                                    <tr><td>Líneas de código (core)</td><td>~2500</td><td>~700</td></tr>
                                    <tr><td>Estado</td><td>Distribuido</td><td>Centralizado (__MIZU.State)</td></tr>
                                    <tr><td>Persistencia</td><td>Adaptadores</td><td>Directa en core</td></tr>
                                    <tr><td>Eventos</td><td>Wildcards</td><td>Pub/Sub simple</td></tr>
                                    <tr><td>Navegación</td><td>Módulo separado</td><td>Integrada en dock</td></tr>
