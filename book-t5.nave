// guía de creación de naves e instrucciones para IA.
// Versión: 3.0.0
// SPDX-License-Identifier: AGPL-3.0-or-later

(function bookT5() {
    'use strict';

    const APP_NAME = 'book-t5';
    const VERSION = '3.0.0';

    // ---- Definición de páginas (15 páginas) ----
    const PAGES = {

        // 1. Portada
        page01: {
            id: 'page01',
            label: '🚀 Portada v2.2.0',
            tomo: 5,
            render: function(container) {
                container.innerHTML = `
                    <div style="text-align: center; padding: 2rem 1rem; font-family: system-ui, sans-serif;">
                        <div style="font-size: 4rem; margin-bottom: 1rem;">📚</div>
                        <h1 style="font-size: 3rem; color: #2c3e50; margin: 0.5rem 0;">VaciOS v2.2.0</h1>
                        <h2 style="font-size: 2rem; color: #34495e; margin: 0.5rem 0;">El Puerto Espacial</h2>
                        <p style="font-size: 1.4rem; color: #7f8c8d; margin: 1rem 0;">Arquitectura Minimalista · 7 Módulos</p>
                        <div style="border-top: 2px dashed #bdc3c7; width: 60%; margin: 2rem auto; padding-top: 1.5rem; opacity: 0.7;">
                            <p style="font-size: 1.1rem;">"El muelle espera, la nave atraca, el usuario explora."</p>
                            <p style="margin-top: 0.5rem; font-size: 0.9rem;">Moisés Núñez · 2026</p>
                        </div>
                        <div style="margin-top: 2rem; background: #ecf0f1; border-radius: 12px; padding: 1rem; display: inline-block;">
                            <span style="font-weight: bold;">📖 Tomo 5 – Guía Completa del Sistema</span>
                        </div>
                    </div>
                `;
            }
        },

        // 2. Introducción
        page02: {
            id: 'page02',
            label: '📖 Introducción',
            tomo: 5,
            render: function(container) {
                container.innerHTML = `
                    <div style="padding: 1rem 0.5rem;">
                        <h2 class="chapter-title">📖 ¿Qué es VaciOS?</h2>
                        <div class="explain-box">
                            <div class="emoji-deco">🧠</div>
                            <p><strong>VaciOS</strong> es un sistema modular para crear aplicaciones web sin servidor, basado en una metáfora de puerto espacial:</p>
                            <ul class="friendly-list">
                                <li><strong>Naves</strong> — las aplicaciones (archivos .nave).</li>
                                <li><strong>Muelle</strong> — el contenedor donde se muestran (dock.mizu).</li>
                                <li><strong>Jefe del muelle</strong> — orquesta el atraque y la activación (dockmaster.mizu).</li>
                                <li><strong>Grúa</strong> — carga los archivos (hauler.mizu).</li>
                                <li><strong>Faro</strong> — da color y estilo (lighthouse.mizu).</li>
                                <li><strong>Centro de operaciones</strong> — panel de control (opscenter.mizu).</li>
                                <li><strong>Núcleo</strong> — el faro que emite señales (core.mizu).</li>
                            </ul>
                            <p>Todo funciona con un único archivo JavaScript (<code>ignite.js</code>) que carga el resto de módulos escritos en <code>.mizu</code>.</p>
                        </div>
                        <div class="concept-grid">
                            <div class="concept-card">
                                <span class="card-icon">🎯</span>
                                <div class="card-title">Responsabilidad Única</div>
                                <div class="card-desc">Cada módulo hace una cosa y la hace bien.</div>
                            </div>
                            <div class="concept-card">
                                <span class="card-icon">🔗</span>
                                <div class="card-title">Eventos</div>
                                <div class="card-desc">Comunicación desacoplada entre módulos.</div>
                            </div>
                            <div class="concept-card">
                                <span class="card-icon">💾</span>
                                <div class="card-title">Persistencia</div>
                                <div class="card-desc">Estado guardado en localStorage, sin funciones.</div>
                            </div>
                        </div>
                    </div>
                `;
            }
        },

        // 3. core.mizu (el núcleo)
        page03: {
            id: 'page03',
            label: '⚙️ core.mizu',
            tomo: 5,
            render: function(container) {
                container.innerHTML = `
                    <div style="padding: 1rem 0.5rem;">
                        <h2 class="chapter-title">⚙️ core.mizu – El Faro</h2>
                        <div class="explain-box">
                            <div class="emoji-deco">💡</div>
                            <p><strong>Responsabilidad:</strong> Estado global, persistencia en localStorage y bus de eventos.</p>
                            <p><strong>Funciones principales:</strong></p>
                            <ul class="friendly-list">
                                <li><code>State</code> – objeto único con todo el estado (tema, app activa, página actual, apps, whitelist…).</li>
                                <li><code>save()</code> / <code>load()</code> – guarda y recupera el estado (sin funciones).</li>
                                <li><code>on(event, fn)</code> / <code>emit(event, data)</code> – sistema de eventos pub/sub.</li>
                                <li><code>setTheme()</code>, <code>setActiveApp()</code>, <code>setCurrentPage()</code>, <code>setStandby()</code> – modificadores del estado con emisión automática.</li>
                            </ul>
                            <p><strong>No contiene</strong> lógica de negocio de apps (eso es tarea de <code>dockmaster.mizu</code>).</p>
                        </div>
                        <div class="code-block">
                            <span class="code-label">📄 Ejemplo de uso</span>
                            <pre>// Obtener el estado
const state = __MIZU.State;
// Suscribirse a cambios de tema
__MIZU.on('theme:changed', (data) => {
    console.log('Nuevo tema:', data.theme);
});
// Cambiar tema
__MIZU.setTheme('dark');</pre>
                        </div>
                    </div>
                `;
            }
        },

        // 4. hauler.mizu (la grúa)
        page04: {
            id: 'page04',
            label: '🏗️ hauler.mizu',
            tomo: 5,
            render: function(container) {
                container.innerHTML = `
                    <div style="padding: 1rem 0.5rem;">
                        <h2 class="chapter-title">🏗️ hauler.mizu – La Grúa</h2>
                        <div class="explain-box">
                            <div class="emoji-deco">🦾</div>
                            <p><strong>Responsabilidad:</strong> Carga dinámica de scripts (.js, .mizu, .nave) mediante inserción de <code>&lt;script&gt;</code>.</p>
                            <p><strong>Características:</strong></p>
                            <ul class="friendly-list">
                                <li>Compatible con <code>file://</code> (sin CORS).</li>
                                <li>Caché en memoria para evitar recargas duplicadas.</li>
                                <li>Control de concurrencia: no carga el mismo script dos veces en paralelo.</li>
                                <li>Fallback con parámetro anti-caché si la carga falla.</li>
                                <li>Timeout de 15 segundos por script.</li>
                                <li>Emite eventos <code>hauler:loaded</code> / <code>hauler:error</code> a través de <code>__MIZU</code>.</li>
                            </ul>
                        </div>
                        <div class="code-block">
                            <span class="code-label">📄 Ejemplo</span>
                            <pre>// Cargar una nave
await __HAULER.loadScript('mi-nave.nave');
// Cargar múltiples en paralelo
await __HAULER.loadMany(['modulo1.mizu', 'modulo2.mizu']);</pre>
                        </div>
                    </div>
                `;
            }
        },

        // 5. dockmaster.mizu (el jefe del muelle)
        page05: {
            id: 'page05',
            label: '⚓ dockmaster.mizu',
            tomo: 5,
            render: function(container) {
                container.innerHTML = `
                    <div style="padding: 1rem 0.5rem;">
                        <h2 class="chapter-title">⚓ dockmaster.mizu – El Jefe del Muelle</h2>
                        <div class="explain-box">
                            <div class="emoji-deco">🚢</div>
                            <p><strong>Responsabilidad:</strong> Orquestar el ciclo de vida de las naves (aplicaciones).</p>
                            <p><strong>Funciones principales:</strong></p>
                            <ul class="friendly-list">
                                <li><code>registerApp(name, definition)</code> – registra una nave con su definición.</li>
                                <li><code>registerPage(appName, pageId, renderFn, label, tomo)</code> – registra una página dentro de una nave.</li>
                                <li><code>registerOrgan(appName, organId, definition)</code> – registra un servicio en segundo plano.</li>
                                <li><code>loadApp(name)</code> – carga una nave desde su archivo <code>.nave</code> y la activa.</li>
                                <li><code>activateApp(name)</code> – activa una nave ya registrada (carga páginas si es necesario).</li>
                                <li><code>unloadApp(name)</code> – desactiva y elimina una nave del sistema.</li>
                            </ul>
                            <p><strong>Solo carga archivos <code>.nave</code> (seguridad).</strong></p>
                        </div>
                        <div class="code-block">
                            <span class="code-label">📄 Ejemplo de registro</span>
                            <pre>__DOCKMASTER.registerApp('mi-app', {
    fullscreen: false,
    load: async function() {
        __DOCKMASTER.registerPage('mi-app', 'inicio', (c) => {
            c.innerHTML = '&lt;h1&gt;Hola VaciOS&lt;/h1&gt;';
        }, 'Inicio', 1);
        return true;
    }
});</pre>
                        </div>
                    </div>
                `;
            }
        },

        // 6. lighthouse.mizu (el faro de colores)
        page06: {
            id: 'page06',
            label: '🌈 lighthouse.mizu',
            tomo: 5,
            render: function(container) {
                container.innerHTML = `
                    <div style="padding: 1rem 0.5rem;">
                        <h2 class="chapter-title">🌈 lighthouse.mizu – El Faro de Colores</h2>
                        <div class="explain-box">
                            <div class="emoji-deco">🎨</div>
                            <p><strong>Responsabilidad:</strong> Gestionar los temas visuales (light, dark, book).</p>
                            <p><strong>Características:</strong></p>
                            <ul class="friendly-list">
                                <li>Inyección dinámica de CSS en el <code>&lt;head&gt;</code>.</li>
                                <li>Tres temas predefinidos: <strong>light</strong> (claro), <strong>dark</strong> (oscuro), <strong>book</strong> (infantil).</li>
                                <li>Persistencia del tema a través de <code>__MIZU.State.theme</code>.</li>
                                <li>Suscrito al evento <code>theme:changed</code> de <code>__MIZU</code>.</li>
                                <li>API: <code>applyTheme(theme)</code>, <code>getCurrentTheme()</code>, <code>toggleTheme()</code>.</li>
                            </ul>
                        </div>
                        <div class="concept-grid">
                            <div class="concept-card">
                                <span class="card-icon">☀️</span>
                                <div class="card-title">Light</div>
                                <div class="card-desc">Fondo claro, contraste alto.</div>
                            </div>
                            <div class="concept-card">
                                <span class="card-icon">🌙</span>
                                <div class="card-title">Dark</div>
                                <div class="card-desc">Fondo oscuro, ideal para juegos.</div>
                            </div>
                            <div class="concept-card">
                                <span class="card-icon">📖</span>
                                <div class="card-title">Book</div>
                                <div class="card-desc">Estilo infantil con bordes redondeados.</div>
                            </div>
                        </div>
                    </div>
                `;
            }
        },

        // 7. dock.mizu (el muelle)
        page07: {
            id: 'page07',
            label: '🛥️ dock.mizu',
            tomo: 5,
            render: function(container) {
                container.innerHTML = `
                    <div style="padding: 1rem 0.5rem;">
                        <h2 class="chapter-title">🛥️ dock.mizu – El Muelle</h2>
                        <div class="explain-box">
                            <div class="emoji-deco">🏗️</div>
                            <p><strong>Responsabilidad:</strong> Renderizar la interfaz de usuario.</p>
                            <p><strong>Características:</strong></p>
                            <ul class="friendly-list">
                                <li>Se suscribe a eventos de <code>__MIZU</code> (<code>app:activated</code>, <code>page:changed</code>, <code>standby:changed</code>).</li>
                                <li>Renderiza el layout clásico (header, navbar, pages-container, footer).</li>
                                <li>Soporte para naves fullscreen (delega en <code>renderFullscreen</code>).</li>
                                <li>Navegación por pestañas, botones Anterior/Siguiente y teclado (flechas).</li>
                                <li>Roles ARIA y atributos de accesibilidad.</li>
                            </ul>
                            <p><strong>No contiene</strong> lógica de negocio; solo pinta lo que el estado indica.</p>
                        </div>
                    </div>
                `;
            }
        },

        // 8. opscenter.mizu (centro de operaciones)
        page08: {
            id: 'page08',
            label: '🖥️ opscenter.mizu',
            tomo: 5,
            render: function(container) {
                container.innerHTML = `
                    <div style="padding: 1rem 0.5rem;">
                        <h2 class="chapter-title">🖥️ opscenter.mizu – Centro de Operaciones</h2>
                        <div class="explain-box">
                            <div class="emoji-deco">📡</div>
                            <p><strong>Responsabilidad:</strong> Panel de control flotante para el usuario.</p>
                            <p><strong>Funciones:</strong></p>
                            <ul class="friendly-list">
                                <li>Listado de naves atracadas con botones para activar/desactivar.</li>
