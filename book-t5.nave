        // 11. Pros y contras
        page11: {
            id: 'page11',
            label: '✅ Pros y Contras',
            tomo: 5,
            render: function(container) {
                container.innerHTML = `
                    <div style="padding: 1rem 0.5rem;">
                        <h2 class="chapter-title">✅ Pros y Contras</h2>
                        <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
                            <div class="explain-box" style="border-color:#28a745;">
                                <div class="emoji-deco">✅</div>
                                <h3 style="margin-top:0;">Pros</h3>
                                <ul class="friendly-list">
                                    <li>Ultra‑minimalista y fácil de entender.</li>
                                    <li>Sin dependencias externas.</li>
                                    <li>100% compatible con file:// (sin servidor).</li>
                                    <li>Modular y extensible.</li>
                                    <li>Persistencia automática en localStorage.</li>
                                    <li>Seguridad por whitelist y modo estricto.</li>
                                    <li>Accesibilidad y navegación por teclado.</li>
                                    <li>Soporte para apps fullscreen.</li>
                                </ul>
                            </div>
                            <div class="explain-box" style="border-color:#dc3545;">
                                <div class="emoji-deco">❌</div>
                                <h3 style="margin-top:0;">Contras</h3>
                                <ul class="friendly-list">
                                    <li>No tiene sandboxing (las apps comparten el mismo DOM).</li>
                                    <li>No soporta IndexedDB por defecto (solo localStorage).</li>
                                    <li>Requiere servidor HTTP para cargar .mizu/.nave con fetch (si se usa).</li>
                                    <li>No tiene soporte para plugins externos.</li>
                                    <li>Curva de aprendizaje para la metáfora del puerto.</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                `;
            }
        },

