        // 13. Cómo crear una nave (app)
        page13: {
            id: 'page13',
            label: '🚀 Crear una nave',
            tomo: 5,
            render: function(container) {
                container.innerHTML = `
                    <div style="padding: 1rem 0.5rem;">
                        <h2 class="chapter-title">🚀 Cómo crear una nave (app)</h2>
                        <div class="explain-box">
                            <div class="emoji-deco">📝</div>
                            <p><strong>Pasos:</strong></p>
                            <ol class="friendly-list" style="list-style-type:decimal; padding-left:1.5rem;">
                                <li><strong>Define tu nave</strong> en un archivo <code>.nave</code>.</li>
                                <li>Usa <code>__DOCKMASTER.registerApp(nombre, definición)</code> dentro del archivo.</li>
                                <li>Define el método <code>load()</code> que registrará las páginas con <code>__DOCKMASTER.registerPage()</code>.</li>
                                <li>Cada página debe tener una función <code>render(container)</code> que pinte su contenido.</li>
                                <li>Para apps fullscreen, añade <code>fullscreen: true</code> y define <code>renderFullscreen(container)</code>.</li>
                                <li>Carga tu nave desde OpsCenter (botón 📂 Atracar nave) o desde la consola con <code>__DOCKMASTER.loadApp('nombre')</code>.</li>
                            </ol>
                        </div>
                        <div class="code-block">
                            <span class="code-label">📄 Ejemplo mínimo</span>
                            <pre>// mi-nave.nave
(function() {
    const APP = 'mi-nave';
    __DOCKMASTER.registerApp(APP, {
        fullscreen: false,
        load: async function() {
            __DOCKMASTER.registerPage(APP, 'inicio', (c) => {
                c.innerHTML = '&lt;h1&gt;¡Bienvenido a bordo!&lt;/h1&gt;';
            }, 'Inicio', 1);
            return true;
        }
    });
})();</pre>
                        </div>
                    </div>
                `;
            }
        },

        // 14. Instrucciones para IA
        page14: {
            id: 'page14',
            label: '🤖 Instrucciones para IA',
            tomo: 5,
            render: function(container) {
                container.innerHTML = `
                    <div style="padding: 1rem 0.5rem;">
                        <h2 class="chapter-title">🤖 Cómo pedirle a una IA que genere una nave</h2>
                        <div class="explain-box">
                            <div class="emoji-deco">🧠</div>
                            <p><strong>Prompt recomendado:</strong></p>
                            <div class="code-block" style="background:#1a2a3a; border-color:#3d5a80;">
                                <pre style="color:#d4e6f1;">"Necesito crear una aplicación para VaciOS v2.2.0.
La app se llamará 'mi-app' y tendrá 2 páginas:
- 'inicio': muestra un mensaje de bienvenida.
- 'acerca': muestra información del autor.
La app debe ser fullscreen: false (modo legado).
Genera el código completo en un archivo .nave."</pre>
                            </div>
                            <p><strong>La IA generará:</strong></p>
                            <ul class="friendly-list">
                                <li>Un archivo <code>.nave</code> con la estructura correcta.</li>
                                <li>Registro con <code>__DOCKMASTER.registerApp()</code>.</li>
                                <li>Páginas registradas con <code>__DOCKMASTER.registerPage()</code>.</li>
                                <li>Función <code>load()</code> asíncrona que retorna <code>true</code>.</li>
                                <li>HTML dentro de <code>render()</code> usando clases CSS de VaciOS (opcional).</li>
                            </ul>
                            <p><strong>Puedes pedir:</strong></p>
                            <ul class="friendly-list">
                                <li>"Añade un juego simple de adivinanza."</li>
                                <li>"Haz que sea fullscreen con un canvas."</li>
                                <li>"Incluye un botón que cambie el tema usando __MIZU.setTheme()."</li>
                            </ul>
                        </div>
                    </div>
                `;
            }
        },

        // 15. Colofón
        page15: {
            id: 'page15',
            label: '🏁 Colofón',
            tomo: 5,
            render: function(container) {
                container.innerHTML = `
                    <div style="text-align: center; padding: 2rem 1rem; font-family: system-ui, sans-serif;">
                        <div style="font-size: 4rem; margin-bottom: 1rem;">🏁</div>
                        <h1 style="font-size: 2.5rem; color: #2c3e50; margin: 0.5rem 0;">¡Has completado el Tomo 5!</h1>
                        <p style="font-size: 1.2rem; color: #7f8c8d; max-width: 600px; margin: 1rem auto;">
                            Ahora conoces la arquitectura de VaciOS v2.2.0, cada uno de sus módulos,
                            y cómo crear tus propias naves.
                        </p>
                        <div style="border-top: 2px dashed #bdc3c7; width: 60%; margin: 2rem auto; padding-top: 1.5rem; opacity: 0.7;">
                            <p style="font-size: 1.1rem;">"El conocimiento es el combustible de la nave."</p>
                            <p style="margin-top: 0.5rem; font-size: 0.9rem;">— Moisés Núñez</p>
                        </div>
                        <div style="margin-top: 2rem; display:flex; justify-content:center; gap:1rem; flex-wrap:wrap;">
                            <span style="background:#ecf0f1; padding:0.5rem 1rem; border-radius:20px;">📚 15 páginas</span>
                            <span style="background:#ecf0f1; padding:0.5rem 1rem; border-radius:20px;">⚙️ 7 módulos</span>
                            <span style="background:#ecf0f1; padding:0.5rem 1rem; border-radius:20px;">🚀 1 puerto</span>
                        </div>
                    </div>
                `;
            }
        }
    };

    // ---- Carga de la nave ----
    async function load() {
        console.log(`[${APP_NAME}] Atracando nave v${VERSION}...`);
        try {
            for (const [id, page] of Object.entries(PAGES)) {
                __DOCKMASTER.registerPage(APP_NAME, id, page.render, page.label, page.tomo);
                console.log(`[${APP_NAME}] Página '${id}' registrada.`);
            }
            console.log(`[${APP_NAME}] ✅ Nave lista (${Object.keys(PAGES).length} páginas).`);
            return true;
        } catch (err) {
            console.error(`[${APP_NAME}] Error en load():`, err);
            return false;
        }
    }

    // ---- Registrar la nave ----
    if (typeof window !== 'undefined' && window.__DOCKMASTER) {
        const D = window.__DOCKMASTER;
        console.log('[book-t5] __DOCKMASTER disponible. Registrando nave...');
        D.registerApp(APP_NAME, {
            fullscreen: false,
            description: 'Tomo 5: VaciOS v2.2.0 – Guía Completa del Sistema (15 páginas)',
            version: VERSION,
            load: load,
            onActivate: () => console.log(`[${APP_NAME}] Nave activada.`),
            onDeactivate: () => console.log(`[${APP_NAME}] Nave desactivada.`)
        });
        console.log(`✅ [${APP_NAME}] Registrada en __DOCKMASTER (v${VERSION}).`);
    } else {
        console.warn('[book-t5] __DOCKMASTER no disponible. Esperando...');
        setTimeout(() => {
            if (window.__DOCKMASTER) {
                const D = window.__DOCKMASTER;
                console.log('[book-t5] __DOCKMASTER ahora disponible. Registrando...');
                D.registerApp(APP_NAME, {
                    fullscreen: false,
                    description: 'Tomo 5: VaciOS v2.2.0 – Guía Completa del Sistema (15 páginas)',
                    version: VERSION,
                    load: load,
                    onActivate: () => console.log(`[${APP_NAME}] Nave activada.`),
                    onDeactivate: () => console.log(`[${APP_NAME}] Nave desactivada.`)
                });
                console.log(`✅ [${APP_NAME}] Registrada en __DOCKMASTER (v${VERSION}).`);
            } else {
                console.error('[book-t5] __DOCKMASTER no disponible incluso después de esperar.');
            }
        }, 100);
    }
})();